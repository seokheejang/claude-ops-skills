  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "__REPO_DIR__/scripts/pretooluse-bash.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "_comment": "macOS: notify when task completes (skips if VSCode/iTerm is focused)",
        "hooks": [
          {
            "type": "command",
            "command": "FRONT=$(osascript -e 'tell application \"System Events\" to get name of first application process whose frontmost is true'); if [ -n \"$VSCODE_PID\" ] && ([ \"$FRONT\" = \"Electron\" ] || [ \"$FRONT\" = \"Code\" ]); then exit 0; elif [ \"$TERM_PROGRAM\" = \"iTerm.app\" ] && [ \"$FRONT\" = \"iTerm2\" ]; then exit 0; else osascript -e 'display notification \"Task Complete\" with title \"Claude Code\" sound name \"Glass\"'; fi"
          }
        ]
      }
    ]
  }
